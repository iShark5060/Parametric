{
  "name": "parametric",
  "version": "2.2.0",
  "private": true,
  "description": "Parametric - Warframe Mod Builder/Planner",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.server.json && vite build",
    "validate": "node run-quality-checks.mjs",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.json --noEmit",
    "start": "node dist/server/index.js",
    "data:import": "node dist/server/import/runManualImport.js",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "check-format": "oxfmt --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.61.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "better-sqlite3": "^12.9.0",
    "better-sqlite3-session-store": "^0.1.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "csrf-sync": "^4.2.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "html-to-image": "^1.11.13",
    "lzma": "^2.3.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "domhandler": "^6.0.1",
    "globals": "^17.5.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=25.0.0",
    "pnpm": ">=11.0.0-rc.0"
  },
  "packageManager": "pnpm@11.0.0-rc.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "overrides": {
      "undici": ">=7.24.4"
    }
  }
}
