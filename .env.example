# --------------------- Server Settings ----------------------
PORT=3002
HOST=127.0.0.1
NODE_ENV=production
HELMINTH_WIKI_USER_AGENT="DarkAvianLabs-Parametric/1.0 (+https://parametric.darkavianlabs.com)"

# ------------------- Application Settings -------------------
APP_PUBLIC_BASE_URL=https://parametric.darkavianlabs.com

# ------------------- Session Settings -----------------------
SESSION_SECRET=change-this-to-a-long-random-string
SESSION_COOKIE_NAME=darkavianlabs.parametric.sid
AUTH_FETCH_TIMEOUT_MS=5000

# -------------------- Proxy Settings ------------------------
TRUST_PROXY=1
SECURE_COOKIES=1

# ------------------- Cookie Settings ------------------------
COOKIE_DOMAIN=.darkavianlabs.com

# ------------------- Auth Service ---------------------------
AUTH_SERVICE_URL=https://auth.darkavianlabs.com

# ------------------- Databases ------------------------------
CENTRAL_DB_PATH=./data/central.db

# ------------------- Vite Settings --------------------------
VITE_APP_NAME=Parametric
VITE_LEGAL_ENTITY_NAME=Dark Avian Labs
VITE_LEGAL_PAGE_URL=/auth/legal
VITE_SHARED_THEME_COOKIE_DOMAIN=.darkavianlabs.com
